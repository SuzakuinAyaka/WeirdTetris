<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayoutGame"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/gameRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnExitGame"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:paddingVertical="0dp"
                        android:text="@string/exit_game" />

                    <Button
                        android:id="@+id/btnGameShop"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:paddingVertical="0dp"
                        android:text="@string/game_shop" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnOpenDrawerShop"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginTop="4dp"
                    android:minHeight="0dp"
                    android:paddingVertical="0dp"
                    android:text="@string/shop_panel_title" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:minHeight="108dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvGameCoins"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCoinIncomeHint"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:minEms="3"
                                android:textAlignment="viewEnd"
                                android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                                android:textColor="?attr/colorPrimary"
                                android:visibility="invisible" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvGameScore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                        <TextView
                            android:id="@+id/tvGameHighScore"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                        <TextView
                            android:id="@+id/tvGameLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                        <TextView
                            android:id="@+id/tvGameLines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall" />

                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvGameMode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:minHeight="108dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/next_piece"
                            android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:foregroundGravity="center"
                            android:paddingVertical="2dp">

                            <com.example.els.ui.widget.NextPieceView
                                android:id="@+id/nextPieceView"
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:layout_gravity="center" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvFreezeHint"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="?attr/colorPrimary"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.example.els.ui.widget.TetrisBoardView
                android:id="@+id/boardView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="2"
                android:padding="6dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <GridLayout
                    android:id="@+id/quickSlotsPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:rowCount="2">

                    <Button
                        android:id="@+id/btnQuickCount1"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_column="0"
                        android:layout_columnWeight="1"
                        android:layout_row="0"
                        android:backgroundTint="?attr/colorSurfaceVariant"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <Button
                        android:id="@+id/btnQuickSlot3"
                        android:layout_width="0dp"
                        android:layout_height="78dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:layout_column="1"
                        android:layout_columnWeight="1"
                        android:layout_row="0"
                        android:layout_rowSpan="2"
                        android:gravity="center"
                        android:maxLines="2" />

                    <Button
                        android:id="@+id/btnQuickCount2"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_column="2"
                        android:layout_columnWeight="1"
                        android:layout_row="0"
                        android:backgroundTint="?attr/colorSurfaceVariant"
                        android:clickable="false"
                        android:focusable="false"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <Button
                        android:id="@+id/btnQuickSlot1"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:layout_column="0"
                        android:layout_columnWeight="1"
                        android:layout_row="1"
                        android:gravity="center"
                        android:maxLines="2" />

                    <Button
                        android:id="@+id/btnQuickSlot2"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_marginTop="6dp"
                        android:layout_column="2"
                        android:layout_columnWeight="1"
                        android:layout_row="1"
                        android:gravity="center"
                        android:maxLines="2" />
                </GridLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/operationBarTablet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnMoveLeft"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="&#8592;" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRotate"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:contentDescription="@string/rotate"
                android:text=""
                app:icon="@drawable/ic_rotate_24"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconTint="?attr/colorOnPrimary" />

            <Button
                android:id="@+id/btnSoftDrop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:text="&#8595;" />

            <Button
                android:id="@+id/btnMoveRight"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="&#8594;" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?attr/colorSurface"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/shop_panel_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerCoins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerBuyLineClear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/item_line_clear" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerBuyBomb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/item_bomb_next" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerBuyFreeze"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/item_freeze" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerBuyFries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/item_fries" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerBuyIncomeBoost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/item_income_boost" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerBuyDestroyCurrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/item_destroy_current" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
