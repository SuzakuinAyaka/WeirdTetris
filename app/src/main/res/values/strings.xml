    <string name="tutorial_entry_desc">Learn controls, mode rules, scoring and coins.</string>
    <string name="tutorial_title">Game Tutorial</string>
    <string name="tutorial_subtitle">Core rules and progression at a glance.</string>
    <string name="tutorial_basic_title">Basic Controls</string>
    <string name="tutorial_basic_body">Move with left/right buttons.\nRotate with rotate button.\nHold down drop button for fast descent.\nDouble tap drop button to instantly hard drop.\nLeft/right support long press for continuous movement.</string>
    <string name="tutorial_style_title">Classic vs Item Mode</string>
    <string name="tutorial_style_body">Classic Mode: no item usage and no coin rewards.\nItem Mode: items can be purchased and used, and line clears grant coins.</string>
    <string name="tutorial_mode_type_title">Endless vs Challenge</string>
    <string name="tutorial_mode_type_body">Endless: speed stays stable for a relaxed run.\nChallenge: speed increases as level rises.</string>
    <string name="tutorial_score_title">Scoring Rules</string>
    <string name="tutorial_score_body">Clear 1/2/3/4 lines grants 100/300/500/800 base score.\nFinal score gain is multiplied by current level.</string>
    <string name="tutorial_level_title">Leveling Rules</string>
    <string name="tutorial_level_body">Every 10 cleared lines increases level by 1.\nHigher level means faster falling speed in Challenge mode.</string>
    <string name="tutorial_coin_title">Coin Rules</string>
    <string name="tutorial_coin_body">Coins are earned only in Item Mode.\nEach cleared line gives 10 coins, and a 4-line clear gives extra +20 coins.\nIncome Boost item triples line-clear coin income for 1 minute.</string>
